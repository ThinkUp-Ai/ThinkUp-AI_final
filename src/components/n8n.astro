---
---

<section class="relative bg-black text-white py-20 px-6 overflow-hidden">
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute -left-40 top-20 h-[420px] w-[420px] rounded-full bg-[#58FFE9]/10 blur-[120px]"></div>
    <div class="absolute -right-40 bottom-20 h-[420px] w-[420px] rounded-full bg-[#58FFE9]/10 blur-[120px]"></div>
  </div>

  <div class="relative z-10 mx-auto max-w-6xl">
    <div class="grid items-center gap-10 lg:grid-cols-[0.95fr_1.05fr]">
      
      <div class="pt-8 md:pt-0">
        <span class="inline-flex rounded-full border border-[#58FFE9]/35 bg-[#58FFE9]/10 px-4 py-2 text-xs font-bold uppercase tracking-[0.18em] text-[#58FFE9]">
          KI-Automatisierung
        </span>

        <h2 class="mt-6 text-3xl font-extrabold leading-tight md:text-5xl">
          Eine Lösung für Ihre komplette
          <span class="text-[#58FFE9]"> Kundenkommunikation.</span>
        </h2>

        <p class="mt-5 max-w-xl text-base leading-7 text-white/70 md:text-lg">
          Ihr KI-Agent beantwortet Fragen, bucht Termine, verschickt Erinnerungen
          und unterstützt bei Aktionen – über WhatsApp, Instagram, Website oder Telefon.
        </p>

        <div class="mt-7 grid gap-4 sm:grid-cols-2">
          <div class="rounded-2xl border border-white/10 bg-white/5 p-5">
            <h3 class="font-bold text-white">FAQ automatisch</h3>
            <p class="mt-2 text-sm leading-6 text-white/60">Antworten auf Standardfragen – sofort und 24/7.</p>
          </div>

          <div class="rounded-2xl border border-white/10 bg-white/5 p-5">
            <h3 class="font-bold text-white">Termine buchen</h3>
            <p class="mt-2 text-sm leading-6 text-white/60">Verfügbarkeit prüfen, Termin bestätigen, Kalender aktualisieren.</p>
          </div>

          <div class="rounded-2xl border border-white/10 bg-white/5 p-5">
            <h3 class="font-bold text-white">Erinnerungen</h3>
            <p class="mt-2 text-sm leading-6 text-white/60">Automatische Reminder reduzieren No-Shows.</p>
          </div>

          <div class="rounded-2xl border border-white/10 bg-white/5 p-5">
            <h3 class="font-bold text-white">Aktionen senden</h3>
            <p class="mt-2 text-sm leading-6 text-white/60">Angebote und Kampagnen direkt an Kunden ausspielen.</p>
          </div>
        </div>
      </div>

      <!-- RIGHT SIDE FIXED -->
      <div class="mx-auto w-full max-w-[460px] rounded-[2rem] border border-[#58FFE9]/25 bg-white/5 p-4 shadow-[0_0_60px_rgba(88,255,233,0.14)]">
        
        <div class="rounded-[1.5rem] border border-white/10 bg-black p-3">
          <img
            src="/begruessungkunde.png"
            alt="Chat-Beispiel: Begrüßung durch KI-Agent"
            class="max-h-[380px] w-full rounded-xl object-contain bg-black"
          />
        </div>

        <div class="mt-4 grid gap-4 sm:grid-cols-2">
          <div class="rounded-2xl border border-white/10 bg-black/45 p-4">
            <p class="text-sm font-bold text-[#58FFE9]">Live im Chat</p>
            <p class="mt-2 text-sm text-white/65">Kunden erhalten direkt Antwort und buchen ohne Wartezeit.</p>
          </div>

          <div class="rounded-2xl border border-white/10 bg-black/45 p-4">
            <p class="text-sm font-bold text-[#58FFE9]">Automatisch im Hintergrund</p>
            <p class="mt-2 text-sm text-white/65">Ihr Team wird weniger unterbrochen und bleibt im Arbeitsflow.</p>
          </div>
        </div>

      </div>
    </div>

    <div class="mt-14">
      <div class="mb-8 text-center">
        <span class="inline-flex rounded-full border border-[#58FFE9]/35 bg-[#58FFE9]/10 px-4 py-2 text-xs font-bold uppercase tracking-[0.18em] text-[#58FFE9]">
          Kundenablauf
        </span>
        <h3 class="mt-4 text-3xl font-extrabold text-white">
          So erlebt Ihr Kunde den Agenten
        </h3>
      </div>

      <div class="grid gap-6 md:grid-cols-3 items-stretch">
        <div class="rounded-[2rem] border border-[#58FFE9]/25 bg-white p-5 text-black shadow-[0_18px_58px_rgba(72,255,235,0.12)] transition duration-300 hover:-translate-y-2 hover:shadow-[0_0_42px_rgba(72,255,235,0.30)]">
          <div class="h-[360px] rounded-[1.5rem] bg-[#0b0b0b] p-3 flex items-center justify-center overflow-hidden">
            <img src="/alternativen.jpg" alt="Terminvorschläge" class="max-h-full max-w-full rounded-xl object-contain" />
          </div>

          <div class="pt-6 min-h-[125px]">
            <p class="text-xs font-black uppercase tracking-[0.18em] text-[#00c9b7]">Schritt 01</p>
            <h3 class="mt-2 text-xl font-black text-black">Passende Termine vorschlagen</h3>
            <p class="mt-3 text-sm leading-6 text-gray-600">
              Der Agent prüft freie Zeiten und bietet passende Alternativen an.
            </p>
          </div>
        </div>

        <div class="rounded-[2rem] border border-[#58FFE9]/25 bg-white p-5 text-black shadow-[0_18px_58px_rgba(72,255,235,0.12)] transition duration-300 hover:-translate-y-2 hover:shadow-[0_0_42px_rgba(72,255,235,0.30)]">
          <div class="h-[360px] rounded-[1.5rem] bg-[#0b0b0b] p-3 flex items-center justify-center overflow-hidden">
            <img src="/termin.jpg" alt="Terminbestätigung" class="max-h-full max-w-full rounded-xl object-contain" />
          </div>

          <div class="pt-6 min-h-[125px]">
            <p class="text-xs font-black uppercase tracking-[0.18em] text-[#00c9b7]">Schritt 02</p>
            <h3 class="mt-2 text-xl font-black text-black">Termin direkt buchen</h3>
            <p class="mt-3 text-sm leading-6 text-gray-600">
              Der Kunde bestätigt im Chat, der Termin wird sauber vorbereitet.
            </p>
          </div>
        </div>

        <div class="rounded-[2rem] border border-[#58FFE9]/25 bg-white p-5 text-black shadow-[0_18px_58px_rgba(72,255,235,0.12)] transition duration-300 hover:-translate-y-2 hover:shadow-[0_0_42px_rgba(72,255,235,0.30)]">
          <div class="h-[360px] rounded-[1.5rem] bg-[#0b0b0b] p-3 flex items-center justify-center overflow-hidden">
            <img src="/erinnerung.jpg" alt="Terminerinnerung" class="max-h-full max-w-full rounded-xl object-contain" />
          </div>

          <div class="pt-6 min-h-[125px]">
            <p class="text-xs font-black uppercase tracking-[0.18em] text-[#00c9b7]">Schritt 03</p>
            <h3 class="mt-2 text-xl font-black text-black">Automatisch erinnern</h3>
            <p class="mt-3 text-sm leading-6 text-gray-600">
              Reminder sorgen für weniger vergessene Termine und mehr Verbindlichkeit.
            </p>
          </div>
        </div>
      </div>
    </div>

    <div class="mt-14 rounded-[2rem] border border-[#58FFE9]/25 bg-[#58FFE9]/[0.04] p-8 text-center">
  <h3 class="text-2xl font-extrabold text-white mb-8">
    Das Ergebnis
  </h3>

  <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-y-6 gap-x-10 max-w-5xl mx-auto text-left">
    
    <div class="flex items-center gap-3">
      <span class="text-[#58FFE9] text-lg">✓</span>
      <p class="text-white/80 text-sm">Weniger Unterbrechungen im Alltag</p>
    </div>

    <div class="flex items-center gap-3">
      <span class="text-[#58FFE9] text-lg">✓</span>
      <p class="text-white/80 text-sm">24/7 erreichbar für Kunden</p>
    </div>

    <div class="flex items-center gap-3">
      <span class="text-[#58FFE9] text-lg">✓</span>
      <p class="text-white/80 text-sm">Mehr Buchungen ohne mehr Personal</p>
    </div>

    <div class="flex items-center gap-3">
      <span class="text-[#58FFE9] text-lg">✓</span>
      <p class="text-white/80 text-sm">Weniger No-Shows durch Erinnerungen</p>
    </div>

    <div class="flex items-center gap-3">
      <span class="text-[#58FFE9] text-lg">✓</span>
      <p class="text-white/80 text-sm">Schnellere Reaktionszeiten</p>
    </div>

    <div class="flex items-center gap-3">
      <span class="text-[#58FFE9] text-lg">✓</span>
      <p class="text-white/80 text-sm">Höhere Kundenzufriedenheit</p>
    </div>

    <!-- NEUE REIHE -->
    <div class="flex items-center gap-3">
      <span class="text-[#58FFE9] text-lg">✓</span>
      <p class="text-white/80 text-sm">Mehr Umsatz durch bessere Auslastung</p>
    </div>

    <div class="flex items-center gap-3">
      <span class="text-[#58FFE9] text-lg">✓</span>
      <p class="text-white/80 text-sm">Weniger manuelle Arbeit im Tagesgeschäft</p>
    </div>

    <div class="flex items-center gap-3">
      <span class="text-[#58FFE9] text-lg">✓</span>
      <p class="text-white/80 text-sm">Strukturierte und saubere Terminverwaltung</p>
    </div>

  </div>
</div>

  </div>
</section>
