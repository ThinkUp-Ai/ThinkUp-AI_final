---
const props = Astro.props as {
  className?: string;
  label?: string;
};

const className = props.className ?? "text-accent underline hover:text-white";
const label = props.label ?? "E-Mail anzeigen";
---

<span data-email-reveal-root>
  <button
    type="button"
    class={className}
    data-email-reveal-button
  >
    {label}
  </button>
</span>

<script is:inline>
  (function () {
    const root = document.currentScript?.previousElementSibling;
    if (!root || !(root instanceof HTMLElement)) return;

    const button = root.querySelector("[data-email-reveal-button]");
    if (!button) return;

    button.addEventListener("click", async () => {
      if (root.querySelector("a[data-email-link]")) return;

      button.setAttribute("disabled", "true");
      button.textContent = "Wird geladen...";

      try {
        const response = await fetch("/api/contact-email", {
          method: "GET",
          headers: {
            Accept: "application/json",
          },
        });

        const data = await response.json().catch(() => null);
        if (!response.ok || typeof data?.email !== "string") {
          throw new Error(data?.error || "E-Mail konnte nicht geladen werden.");
        }

        const link = document.createElement("a");
        link.href = `mailto:${data.email}`;
        link.textContent = data.email;
        link.className = button.className;
        link.setAttribute("data-email-link", "true");
        button.replaceWith(link);
      } catch (error) {
        button.textContent =
          error instanceof Error ? error.message : "E-Mail konnte nicht geladen werden.";
        button.removeAttribute("disabled");
      }
    });
  })();
</script>
