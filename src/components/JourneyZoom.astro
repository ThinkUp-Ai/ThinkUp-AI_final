---
const steps = [
  { 
    title: '1. Produktanfrage', 
    subtitle: 'Sie stellen Ihre Anfrage über unsere Website und geben uns einen ersten Eindruck von Ihrem Unternehmen, Ihren Kanälen und Ihrem gewünschten Use Case.', 
    short: 'Sie fragen Ihre passende KI-Automatisierung an.',
    bg: '/journey/beratung.jpg', 
    animation: '/lottie/Animation1.json' 
  },
  { 
    title: '2. Erstgespräch & Onboarding', 
    subtitle: 'Wir besprechen Ihre Abläufe, Ihre Ziele und Ihre bestehenden Kanäle. Danach legen wir fest, was der Agent übernehmen soll.', 
    short: 'Wir verstehen Ihre Abläufe und definieren den Agenten.',
    bg: '/journey/plan.jpg', 
    animation: '/lottie/Animation2.json' 
  },
  { 
    title: '3. Einrichtung & Integration', 
    subtitle: 'Wir bauen den Agenten, hinterlegen Antworten, Regeln und Terminlogik und verbinden Kalender, Website, WhatsApp, Instagram oder weitere Systeme.', 
    short: 'Wir implementieren Agent, Kanäle und Workflows.',
    bg: '/journey/workshop.jpg', 
    animation: '/lottie/Animation3.json' 
  },
  { 
    title: '4. Go-Live & Optimierung', 
    subtitle: 'Der Agent geht live, beantwortet Anfragen, bucht Termine und entlastet Ihr Team. Danach optimieren wir anhand echter Kundenanfragen weiter.', 
    short: 'Ihr Agent geht live und wird laufend verbessert.',
    bg: '/journey/erfolg.jpg', 
    animation: '/lottie/Animation4.json' 
  }
];
---

<script is:inline src="/lottie/lottie-player.js"></script>

<section class="relative bg-black text-white py-24 px-6 overflow-hidden">
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute left-1/2 top-1/2 h-[520px] w-[520px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-[#58FFE9]/10 blur-[140px]"></div>
  </div>

  <div class="relative z-10 mx-auto max-w-7xl">
    <div class="text-center">
      <span class="inline-flex rounded-full border border-[#58FFE9]/35 bg-[#58FFE9]/10 px-4 py-2 text-xs font-bold uppercase tracking-[0.18em] text-[#58FFE9]">
        Umsetzung
      </span>

      <h2 class="mt-6 text-4xl font-extrabold leading-tight md:text-5xl">
        Ihre Umsetzung in
        <span class="text-[#58FFE9]"> 4 klaren Schritten</span>
      </h2>

      <p class="mx-auto mt-5 max-w-3xl text-base leading-8 text-white/70 md:text-lg">
        Von der ersten Anfrage bis zum Live-Betrieb: Wir übernehmen die technische Umsetzung,
        Sie behalten einen klaren und einfachen Ablauf.
      </p>
    </div>

    <div class="mt-14 grid gap-6 md:grid-cols-2 lg:grid-cols-4">
      {steps.map((step, index) => (
        <div class="rounded-3xl border border-white/10 bg-white/5 p-6 shadow-[0_18px_58px_rgba(72,255,235,0.06)] transition duration-300 hover:-translate-y-2 hover:border-[#58FFE9]/60 hover:shadow-[0_0_42px_rgba(72,255,235,0.24)]">
          <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-2xl bg-[#58FFE9]/15 text-lg font-black text-[#58FFE9]">
            {String(index + 1).padStart(2, '0')}
          </div>

          <h3 class="text-lg font-extrabold text-white">
            {step.title.replace(`${index + 1}. `, '')}
          </h3>

          <p class="mt-3 text-sm leading-6 text-white/65">
            {step.short}
          </p>
        </div>
      ))}
    </div>

    <div class="mt-12 flex justify-center">
      <button
        id="openJourney"
        class="inline-flex items-center justify-center rounded-full bg-[#58FFE9] px-8 py-4 text-sm font-black uppercase tracking-[0.16em] text-black shadow-[0_18px_45px_rgba(72,255,235,0.24)] transition hover:-translate-y-1 hover:brightness-110 hover:shadow-[0_0_45px_rgba(72,255,235,0.48)]"
      >
        Prozess ansehen
      </button>
    </div>
  </div>
</section>

<div id="journeyOverlay" class="fixed inset-0 bg-black bg-opacity-90 hidden flex-col items-center justify-center z-50">
  <div class="absolute bottom-40 w-full flex justify-center z-40 pointer-events-none">
    <p class="text-white text-base md:text-lg bg-black bg-opacity-60 px-4 py-2 rounded-xl">
      👉 Wische nach links, um alle Schritte zu entdecken
    </p>
  </div>

  <button id="arrowLeft" aria-label="Vorheriger Schritt" class="flex absolute left-4 top-1/2 transform -translate-y-1/2 z-50 bg-white bg-opacity-20 hover:bg-opacity-40 rounded-full p-3">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
    </svg>
  </button>

  <button id="arrowRight" aria-label="Nächster Schritt" class="flex absolute right-4 top-1/2 transform -translate-y-1/2 z-50 bg-white bg-opacity-20 hover:bg-opacity-40 rounded-full p-3">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
    </svg>
  </button>

  <div id="journeyTrack" class="transform scale-75 opacity-0 transition-all duration-700 ease-out flex snap-x snap-mandatory overflow-x-auto w-full h-3/4">
    {steps.map((step, i) => (
      <div
        class="flex-shrink-0 w-screen h-full bg-center bg-cover relative snap-start"
        style={`background-image:url('${step.bg}')`}
      >
        <div
          class="absolute inset-0 bg-black bg-opacity-50 flex flex-col justify-center items-center text-center p-4 md:p-8 backdrop-blur-sm opacity-0 transition-opacity duration-500"
          data-step={i}
        >
          <h3 class="text-3xl md:text-4xl font-extrabold text-[#58FFE9] mb-2">{step.title}</h3>
          <p class="text-base md:text-lg max-w-lg mb-6 text-white/80">{step.subtitle}</p>

          <div class="w-full max-w-[150px] h-auto md:max-w-[300px]">
            <lottie-player
              src={step.animation}
              background="transparent"
              speed="1"
              style="width: 100%; height: 100%;" 
              loop
              autoplay
            ></lottie-player>
          </div>
        </div>
      </div>
    ))}
  </div>

  <button
    id="closeJourney"
    class="bg-white text-black font-semibold px-6 py-3 mt-6 rounded-xl shadow-md transition hover:ring-2 hover:ring-[#58FFE9]"
  >
    Schließen
  </button>
</div>

<style>
  html.no-scroll {
    overflow: hidden;
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const htmlElement = document.documentElement;
    const inBtn = document.getElementById('openJourney');
    const outBtn = document.getElementById('closeJourney');
    const overlay = document.getElementById('journeyOverlay');
    const track = document.getElementById('journeyTrack');
    const slides = track ? track.querySelectorAll('.flex-shrink-0') : [];

    const arrowLeft = document.getElementById('arrowLeft');
    const arrowRight = document.getElementById('arrowRight');

    const getIndex = () => track ? Math.round(track.scrollLeft / track.clientWidth) : 0;
    const goToIndex = (idx) => {
      if (!track || slides.length === 0) return;
      const normalized = (idx + slides.length) % slides.length;
      track.scrollTo({ left: normalized * track.clientWidth, behavior: 'smooth' });
    };
    const next = () => goToIndex(getIndex() + 1);
    const prev = () => goToIndex(getIndex() - 1);

    if (arrowLeft && arrowRight && track) {
      arrowLeft.addEventListener('click', prev);
      arrowRight.addEventListener('click', next);
    }

    if (track && slides.length > 0) {
      const io = new IntersectionObserver(entries => {
        entries.forEach(e => {
          if (e.isIntersecting) {
            e.target.querySelector('[data-step]')?.classList.add('opacity-100');
          }
        });
      }, { root: track, threshold: 0.5 });
      slides.forEach(slide => io.observe(slide));
    }

    let keydownHandler;

    if (inBtn && overlay && track) {
      inBtn.addEventListener('click', () => {
        htmlElement.classList.add('no-scroll'); 
        
        overlay.classList.remove('hidden');
        overlay.classList.add('flex');

        setTimeout(() => {
          track.classList.remove('scale-75', 'opacity-0');
          track.classList.add('scale-100', 'opacity-100');
        }, 10);

        keydownHandler = (e) => {
          if (e.key === 'ArrowRight') next();
          if (e.key === 'ArrowLeft') prev();
          if (e.key === 'Escape') outBtn?.click();
        };

        document.addEventListener('keydown', keydownHandler);
      });
    }

    if (outBtn && overlay && track) {
      outBtn.addEventListener('click', () => {
        htmlElement.classList.remove('no-scroll'); 
        
        track.classList.remove('scale-100', 'opacity-100');
        track.classList.add('scale-75', 'opacity-0');

        track.addEventListener('transitionend', () => {
          overlay.classList.remove('flex');
          overlay.classList.add('hidden');
          track.querySelectorAll('[data-step]')?.forEach(el => el.classList.remove('opacity-100'));

          if (keydownHandler) {
            document.removeEventListener('keydown', keydownHandler);
            keydownHandler = undefined;
          }
        }, { once: true });
      });
    }
  });
</script>