---
import Layout from '../layouts/Layout.astro';
import Container from '../components/Container.astro';

const hasError = Astro.url.searchParams.get("error") === "1";
---

<Layout 
  title="Kundenlogin | ThinkUp-AI" 
  description="Login zum ThinkUp-AI Kundenbereich."
>
  <section class="min-h-screen bg-black px-6 pt-36 pb-24 text-white overflow-hidden">
    <div class="absolute left-[-10rem] top-32 h-[420px] w-[420px] rounded-full bg-[#58FFE9]/10 blur-[120px]"></div>
    <div class="absolute right-[-10rem] bottom-20 h-[420px] w-[420px] rounded-full bg-[#58FFE9]/10 blur-[120px]"></div>

    <Container class="relative z-10 max-w-5xl">
      <div class="mx-auto grid max-w-xl gap-10 text-center lg:max-w-none lg:grid-cols-[0.9fr_1.1fr] lg:items-center lg:text-left">
        
        <div>
          <span class="inline-flex rounded-full border border-[#58FFE9]/35 bg-[#58FFE9]/10 px-4 py-2 text-xs font-bold uppercase tracking-[0.18em] text-[#58FFE9]">
            Kundenbereich
          </span>

          <h1 class="mt-6 text-4xl font-extrabold leading-tight md:text-6xl">
            Login für Ihren 
            <span class="text-[#58FFE9]"> KI-Agenten.</span>
          </h1>

          <p class="mx-auto mt-6 max-w-xl text-base leading-7 text-white/70 md:text-lg lg:mx-0">
            Melden Sie sich an, um Ihren Onboarding-Prozess, Ihre Agenten-Einrichtung
            und später Ihr Dashboard zu verwalten.
          </p>
        </div>

        <div class="mx-auto w-full max-w-lg rounded-[2rem] border border-[#58FFE9]/25 bg-white/5 p-4 shadow-[0_0_60px_rgba(88,255,233,0.14)] sm:p-6">
          <form 
            method="POST"
            action="/api/login"
            class="rounded-[1.5rem] border border-white/10 bg-black p-5 text-left sm:p-6"
          >
            {hasError && (
              <div class="mb-5 rounded-2xl border border-red-400/25 bg-red-500/10 px-4 py-3 text-sm text-red-100">
                E-Mail oder Passwort ist falsch.
              </div>
            )}

            <label class="block">
              <span class="text-sm font-bold text-white">E-Mail</span>
              <input
                name="email"
                type="email"
                placeholder="kunde@unternehmen.de"
                required
                class="mt-2 w-full rounded-2xl border border-white/10 bg-white/5 px-4 py-4 text-white outline-none transition placeholder:text-white/35 focus:border-[#58FFE9]/60"
              />
            </label>

            <label class="mt-5 block">
              <span class="text-sm font-bold text-white">Passwort</span>
              <input
                name="password"
                type="password"
                placeholder="••••••••"
                required
                class="mt-2 w-full rounded-2xl border border-white/10 bg-white/5 px-4 py-4 text-white outline-none transition placeholder:text-white/35 focus:border-[#58FFE9]/60"
              />
            </label>

            <button
              type="submit"
              class="mt-7 w-full rounded-full bg-[#58FFE9] px-7 py-4 text-sm font-bold uppercase tracking-[0.18em] text-black transition hover:scale-[1.02] hover:shadow-[0_0_40px_rgba(88,255,233,0.6)]"
            >
              Einloggen
            </button>

            <p class="mt-5 text-center text-xs leading-5 text-white/45">
              Der Kundenbereich befindet sich aktuell im Aufbau. Zugangsdaten erhalten Kunden nach Projektstart.
            </p>
          </form>
        </div>

      </div>
    </Container>
  </section>
</Layout>
