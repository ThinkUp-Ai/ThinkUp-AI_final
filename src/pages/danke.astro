---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Danke – ThinkUp AI" description="Vielen Dank für deine Anfrage.">
  <section class="px-4 py-24 min-h-[50vh] flex items-center justify-center">
    <div class="max-w-2xl text-center">
      <h1 class="text-2xl md:text-4xl lg:text-5xl font-bold text-accent mb-4">Danke für Ihre Anfrage!</h1>
      <p class="text-white/90">Wir haben Ihre Nachricht erhalten und melden uns in Kürze bei Ihnen.</p>
      <a href="/" class="inline-block mt-8 px-6 py-3 bg-white text-primary rounded-xl font-semibold hover:ring-2 hover:ring-accent">Zurück zur Startseite</a>
    </div>
  </section>
</Layout>
