---
import Layout from '../layouts/Layout.astro';
import Container from '../components/Container.astro';
import PhoneCallDemo from '../components/home/PhoneCallDemo';
import ChannelDetailsSection from '../components/home/ChannelDetailsSection.astro';
---

<Layout
  title="Telefon Agent | ThinkUp"
  description="Termine automatisch buchen, Anfragen automatisch beantworten – ohne Umwege für Ihr Team."
>
  <section class="pt-36 pb-24 px-6 bg-black text-white">
    <Container class="max-w-5xl text-center">
      <h1 class="text-2xl md:text-4xl lg:text-5xl font-extrabold leading-tight text-[#58FFE9]">
        Telefon
      </h1>
      <p class="text-white/70 text-base md:text-lg mt-6 max-w-3xl mx-auto">
        Ihre Kunden können weiterhin ganz einfach telefonisch anfragen, während
        der Agent Anrufe entgegennimmt und Termine vorbereitet. Ihr Team wird
        weniger unterbrochen und muss sich nicht mehr um jeden Anruf selbst kümmern.
      </p>
      <div class="mt-8 flex justify-center">
        <a
          href="/buchen"
          class="inline-flex items-center justify-center rounded-full bg-accent px-7 py-3 text-sm font-semibold uppercase tracking-[0.18em] text-black transition hover:brightness-110"
        >
          Produkt anfragen
        </a>
      </div>
    </Container>
  </section>

  <PhoneCallDemo client:load />
  <ChannelDetailsSection channel="telefon" />
</Layout>
