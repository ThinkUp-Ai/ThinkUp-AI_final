---
// src/pages/kontakt.astro

import Layout from '../layouts/Layout.astro';
import Container from '../components/Container.astro'; // Dein zentraler Container
import EmailReveal from '../components/EmailReveal.astro';
---

<Layout title="Kontakt | ThinkUp" description="Kontaktieren Sie ThinkUp für Terminautomatisierung: Termine automatisch buchen und Anfragen automatisch beantworten.">
  <Container class="max-w-3xl text-center mt-32 mb-20">
    
    <h1 class="text-2xl md:text-4xl lg:text-5xl font-bold text-accent mb-6">Kontakt</h1>

    <p class="mb-2">Sie wollen Termine automatisch buchen und Anfragen automatisch beantworten?</p>
    
    <p>
      Schreiben Sie uns:
      <EmailReveal className="text-accent hover:underline" label="E-Mail anzeigen" />
    </p>
    
    <p> 
      Oder rufen Sie uns an:
      <a href="tel:+4915565658472">
        +49 15565 658472
      </a>
    </p>

  </Container>
</Layout>
