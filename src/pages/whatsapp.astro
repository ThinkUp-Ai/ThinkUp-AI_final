---
import Layout from '../layouts/Layout.astro';
import Container from '../components/Container.astro';
import PremiumChatDemo from '../components/home/PremiumChatDemo';
import ChannelDetailsSection from '../components/home/ChannelDetailsSection.astro';
---

<Layout
  title="WhatsApp Agent | ThinkUp"
  description="Anfragen automatisch beantworten und Termine automatisch buchen – getestet auf Ihrer eigenen Testnummer."
>
  <section class="pt-36 pb-24 px-6 bg-black text-white">
    <Container class="max-w-5xl text-center">
      <h1 class="text-2xl md:text-4xl lg:text-5xl font-extrabold leading-tight text-[#58FFE9]">
        WhatsApp
      </h1>
      <p class="text-white/70 text-base md:text-lg mt-6 max-w-3xl mx-auto">
        Ihre Kunden stellen Terminanfragen direkt über WhatsApp, was besonders
        kundenfreundlich ist. Ihr Team muss sich nicht mehr selbst um die laufende
        Terminbuchung kümmern und wird im Alltag spürbar entlastet.
      </p>
      <div class="mt-8 flex justify-center">
        <a
          href="/buchen"
          class="inline-flex items-center justify-center rounded-full bg-accent px-7 py-3 text-sm font-semibold uppercase tracking-[0.18em] text-black transition hover:brightness-110"
        >
          Produkt anfragen
        </a>
      </div>
    </Container>
  </section>

  <PremiumChatDemo
    client:load
    channel="whatsapp"
    badge="WhatsApp Demo"
    title="WhatsApp Agent testen"
    description="Testen Sie dieselbe sichere Premium-Chat-Erfahrung wie auf der Startseite, vorbereitet für Ihre spätere WhatsApp-Anbindung."
  />
  <ChannelDetailsSection channel="whatsapp" />
</Layout>
